# =============================================================================
# Orca Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#
# --- macOS Notes ---
# Paths use /Users/<you>/... instead of C:\Users\<you>\...
# cloudflared: install via `brew install cloudflared` (binary at /opt/homebrew/bin/cloudflared)
# ORCA_CLOUDFLARED_PATH=/opt/homebrew/bin/cloudflared
# ORCA_DEFAULT_CWD=/Users/<you>/repos/my-project
#
# claude binary: install via `npm install -g @anthropic-ai/claude-code` (or per-project dev dep).
# No .cmd shim resolution is needed on macOS — the `claude` binary resolves directly.
# If `claude` is not on PATH, set ORCA_CLAUDE_PATH to the absolute path, e.g.:
# ORCA_CLAUDE_PATH=/usr/local/bin/claude

# --- Optional fallback ---

# Default working directory for CC sessions (fallback when a project's Linear
# description has no `repo:` line). If every project has a repo: line, this
# can be omitted.
# ORCA_DEFAULT_CWD=/path/to/your/repo

# --- Linear Integration (required) ---

# Linear API key (lin_api_...)
ORCA_LINEAR_API_KEY=lin_api_YOUR_KEY_HERE

# Webhook signing secret for HMAC-SHA256 verification
ORCA_LINEAR_WEBHOOK_SECRET=your_webhook_secret_here

# JSON array of Linear project UUIDs to sync
ORCA_LINEAR_PROJECT_IDS=["project-uuid-1"]

# Cloudflared tunnel public hostname (e.g. orca.example.com)
ORCA_TUNNEL_HOSTNAME=orca.example.com

# Dashboard-managed tunnel token (from Cloudflare Zero Trust dashboard)
# When set, cloudflared uses this token instead of local config files.
# ORCA_TUNNEL_TOKEN=

# Linear state.type that signals readiness for dispatch (default: "unstarted")
# ORCA_LINEAR_READY_STATE_TYPE=unstarted

# --- Scheduler ---

# Max concurrent CC sessions (default: 1)
# ORCA_CONCURRENCY_CAP=1

# Auto-clear drain flag if draining with 0 active sessions for this many minutes (default: 10)
# ORCA_DRAIN_TIMEOUT_MIN=10

# Hard timeout per session in minutes (default: 45)
# ORCA_SESSION_TIMEOUT_MIN=45

# Max retry attempts before permanent failure (default: 3)
# ORCA_MAX_RETRIES=3

# Rolling budget window duration in hours (default: 4)
# ORCA_BUDGET_WINDOW_HOURS=4

# Max cumulative cost (USD) per budget window (default: 100.00)
# ORCA_BUDGET_MAX_COST_USD=100.00

# Max cumulative tokens per budget window (default: 1000000000)
# ORCA_BUDGET_MAX_TOKENS=1000000000

# --- Claude Code ---

# Path to claude CLI binary (default: "claude")
# ORCA_CLAUDE_PATH=claude

# Default max turns per session (default: 50)
# ORCA_DEFAULT_MAX_TURNS=50

# System prompt for implementation agents (default: built-in prompt)
# ORCA_IMPLEMENT_SYSTEM_PROMPT=

# System prompt for the review agent (default: built-in review prompt)
# ORCA_REVIEW_SYSTEM_PROMPT=

# System prompt for the fix agent (default: built-in fix prompt)
# ORCA_FIX_SYSTEM_PROMPT=

# Max review-fix cycles before leaving for human intervention (default: 10)
# ORCA_MAX_REVIEW_CYCLES=10

# Max turns for review agent sessions (default: 30)
# ORCA_REVIEW_MAX_TURNS=30

# Comma-separated list of blocked tools (default: "")
# ORCA_DISALLOWED_TOOLS=

# Resume sessions that hit max turns — preserves worktree and passes
# --resume with the previous session ID (default: true)
# ORCA_RESUME_ON_MAX_TURNS=true

# Resume fix sessions from the prior session (default: true)
# ORCA_RESUME_ON_FIX=true

# Max retries when creating a git worktree fails (default: 3)
# ORCA_MAX_WORKTREE_RETRIES=3

# Number of pre-warmed worktrees to keep ready for instant task dispatch (default: 0, disabled)
# ORCA_WORKTREE_POOL_SIZE=0

# --- Deploy Monitoring ---

# Deploy strategy after PR merge: "none" (skip, mark done immediately) or
# "github_actions" (poll GitHub Actions until CI passes) (default: "none")
# ORCA_DEPLOY_STRATEGY=none

# How often to poll GitHub Actions for deploy status in seconds (default: 30)
# ORCA_DEPLOY_POLL_INTERVAL_SEC=30

# Timeout for deploy monitoring in minutes — task fails if CI doesn't finish (default: 30)
# ORCA_DEPLOY_TIMEOUT_MIN=30

# --- Cleanup ---

# How often the cleanup loop runs in minutes (default: 10)
# ORCA_CLEANUP_INTERVAL_MIN=10

# Minimum age in minutes before a stale orca/* branch is deleted (default: 60)
# ORCA_CLEANUP_BRANCH_MAX_AGE_MIN=60

# Invocation log retention (hours). Logs older than this for completed/failed invocations are deleted.
# ORCA_INVOCATION_LOG_RETENTION_HOURS=168

# Cron job execution retention in days — older records are pruned (default: 7)
# ORCA_CRON_RETENTION_DAYS=7

# --- Logging ---

# Path to the Orca log file (default: ./orca.log)
# ORCA_LOG_PATH=./orca.log

# Max log file size in MB before rotation (default: 10)
# ORCA_LOG_MAX_SIZE_MB=10

# Log output format: "json" emits structured JSON (one object per line with
# timestamp, level, module, message, and any extra fields). Omit or set to any
# other value for the default human-readable format ("[LEVEL] [orca/module] msg").
# Use JSON format in production/CI for log aggregation pipelines.
# LOG_FORMAT=json

# Minimum log level: debug | info | warn | error (default: info).
# LOG_LEVEL=info

# --- Cloudflared ---

# Path to cloudflared binary (default: "cloudflared")
# ORCA_CLOUDFLARED_PATH=cloudflared

# Set to true when cloudflared runs as an external system service.
# Orca will skip spawning cloudflared and treat the tunnel as always connected.
# ORCA_EXTERNAL_TUNNEL=false

# GitHub webhook secret for auto-deploy on push to main (optional)
# ORCA_GITHUB_WEBHOOK_SECRET=

# Webhook URL for permanent failure alerts (Slack/Discord compatible, optional)
# ORCA_ALERT_WEBHOOK_URL=

# --- Monitor ---

# Burn rate threshold for alerts in USD/hour (default: 20)
# Alert fires when budget is spent faster than this rate.
# MONITOR_BURN_RATE_ALERT_USD_PER_HOUR=20

# --- Blue/Green Deploy (Cloudflare Tunnel API) ---
# Required for blue/green deploy script to switch tunnel origin port.
# CLOUDFLARE_TUNNEL_ID=your-tunnel-uuid
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token

# --- Multi-Instance Filtering ---

# Only sync issues that carry this Linear label. When set, Orca skips issues
# that don't have the label during full sync and webhook processing. Useful for
# running multiple Orca instances against the same Linear projects (e.g. one
# per environment or team). When unset, all issues in configured projects are
# synced (default behavior).
# ORCA_TASK_FILTER_LABEL=orca-prod

# JSON object mapping Linear state names to Orca internal statuses. Checked
# before the default type-based mapping — use this to handle edge cases where
# the heuristic produces the wrong result (e.g. a custom "QA Review" state,
# or "Done Pending Deployment" that should map to "done").
# Valid Orca statuses: backlog, ready, running, in_review, done, skip
# "skip" causes the issue to be ignored entirely.
# Example: ORCA_STATE_MAP={"QA Review":"in_review","Done Pending Deployment":"done"}
# ORCA_STATE_MAP=

# --- Server ---

# Local server port (default: 3000)
# ORCA_PORT=3000

# Path to SQLite database file (default: ./orca.db)
# ORCA_DB_PATH=./orca.db

# --- Inngest (self-hosted event queue) ---

# Event key used to authenticate event sends (must match --event-key on the server)
# Any non-empty string works for local dev; use a random secret in production.
# INNGEST_EVENT_KEY=local

# Signing key used to verify function calls from the Inngest server (must match --signing-key)
# Any non-empty string works for local dev; use a random secret in production.
# INNGEST_SIGNING_KEY=local

# URL of the Inngest server (default: http://localhost:8288)
# Set this when running the self-hosted server locally.
# INNGEST_BASE_URL=http://localhost:8288

# --- GitHub MCP Server ---

# GitHub PAT for the official GitHub MCP server (https://api.githubcopilot.com/mcp/).
# When set, agents get structured GitHub tools (PR creation, issue lookup, CI status).
# Fine-grained PAT with repo + pr scopes. Falls back to GITHUB_TOKEN if not set.
# GITHUB_MCP_PAT=
