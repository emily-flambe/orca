{
  "name": "orca",
  "version": "0.1.0",
  "description": "AI agent scheduler — maximizes Claude Code token utilization by dispatching work from Linear to local CC CLI sessions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "orca": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src web/src",
    "test:e2e": "playwright test",
    "inngest:start": "bash scripts/start-inngest.sh",
    "pm2:start": "npx pm2 start ecosystem.config.cjs",
    "pm2:stop": "npx pm2 stop all",
    "pm2:status": "npx pm2 status",
    "pm2:logs": "npx pm2 logs"
  },
  "keywords": [
    "ai",
    "agent",
    "scheduler",
    "claude",
    "orchestrator"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "inngest": "^3.52.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "inngest-cli": "^1.17.5",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "pm2": "^6.0.14",
    "vitest": "^4.1.0"
  }
}
